<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" width="100%" height="100%">
  <defs>
    <!-- Green to Beige Gradient -->
    <linearGradient id="earthyGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3A5A40" /> <!-- Forest Green -->
      <stop offset="100%" stop-color="#C2B280" /> <!-- Sand/Beige -->
    </linearGradient>
    
    <!-- Deep Green to Sage Gradient -->
    <linearGradient id="greenGradient" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#193220" /> <!-- Very Dark Green -->
      <stop offset="100%" stop-color="#588157" /> <!-- Sage Green -->
    </linearGradient>
  </defs>

  <!-- Soft Beige Background -->
  <rect width="400" height="400" rx="40" fill="#F4F1EA" />

  <g transform="translate(70, 40) scale(1.1)">
    <!-- African Continent Shape -->
    <polygon points="160,30 80,30 40,60 20,100 50,130 90,130 100,150 110,200 130,270 150,270 180,210 190,170 240,130 210,100 190,80 170,40" 
             fill="#E8E2D2" 
             stroke="url(#earthyGradient)" 
             stroke-width="6" 
             stroke-linejoin="round" />
    
    <!-- Letter A -->
    <path d="M 100 180 L 80 230 L 95 230 L 100 215 L 115 215 L 120 230 L 135 230 Z M 104 202 L 111 202 L 107.5 190 Z" 
          fill="url(#greenGradient)" />

    <!-- Letter H -->
    <path d="M 145 180 L 160 180 L 160 198 L 175 198 L 175 180 L 190 180 L 190 230 L 175 230 L 175 212 L 160 212 L 160 230 L 145 230 Z" 
          fill="url(#greenGradient)" />
          
    <!-- Connecting Node in Dark Beige -->
    <circle cx="137" cy="205" r="4.5" fill="#A89F80" />
  </g>

  <!-- Webapp Typography -->
  <text x="200" y="340" font-family="Arial, sans-serif" font-weight="900" font-size="32" fill="#193220" text-anchor="middle" letter-spacing="2">
    AFRI<tspan fill="#8DA881">HUSTLE</tspan>
  </text>
  
</svg>